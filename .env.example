# ============================================================
# AI 小说转剧本工具 — 环境变量配置
# ============================================================

# API 提供商选择（支持所有 OpenAI 兼容接口）
# DeepSeek:     API_BASE_URL=https://api.deepseek.com  AI_MODEL=deepseek-chat
# 硅基流动:      API_BASE_URL=https://api.siliconflow.cn/v1  AI_MODEL=deepseek-ai/DeepSeek-V3
# OpenAI:       API_BASE_URL=https://api.openai.com/v1  AI_MODEL=gpt-4o
# 阿里百炼:      API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# API Key（必填）
# DeepSeek 获取地址: https://platform.deepseek.com/
API_KEY=sk-your-deepseek-api-key-here

# API 地址（可选，默认 DeepSeek）
API_BASE_URL=https://api.deepseek.com

# AI 模型（可选）
# deepseek-chat     — 通用对话，性价比最高（推荐）
# deepseek-reasoner — 深度推理，思考过程更细致（效果更好但较慢）
AI_MODEL=deepseek-chat

# 服务器端口（可选）
PORT=3000
